---
import Layout from "./Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import DocsSidebar from "../components/DocsSidebar.astro";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  /** Slug of the active page. Undefined on the docs overview. */
  currentSlug?: string;
  /** Headings from the rendered markdown, used for the "On this page" list. */
  headings?: Heading[];
  /** Path to the markdown source, relative to website/docs, for the edit link. */
  editPath?: string;
}

const {
  title,
  description,
  currentSlug,
  headings = [],
  editPath,
} = Astro.props;

const pageTitle = `${title} · dux docs | getdux.app`;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);

const site = Astro.site ?? new URL("https://getdux.app");
const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: site.toString() },
    {
      "@type": "ListItem",
      position: 2,
      name: "Docs",
      item: new URL("/docs", site).toString(),
    },
    { "@type": "ListItem", position: 3, name: title },
  ],
};

const editUrl = editPath
  ? `https://github.com/patrickdappollonio/dux/blob/main/website/docs/${editPath}`
  : undefined;

const gridClass =
  toc.length > 0
    ? "lg:grid-cols-[15rem_minmax(0,1fr)] xl:grid-cols-[15rem_minmax(0,1fr)_13rem]"
    : "lg:grid-cols-[15rem_minmax(0,1fr)]";
---

<Layout title={pageTitle} description={description} emitStructuredData={false}>
  <Header />
  <main class="container-app py-10 lg:py-14">
    <nav class="mb-6 flex items-center gap-2 text-xs text-[color:var(--color-dim)]" aria-label="Breadcrumb">
      <a href="/" class="inline-flex items-center gap-1.5 hover:text-[color:var(--color-accent)]">
        <svg
          class="h-3.5 w-3.5 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <polyline points="9 22 9 12 15 12 15 22" />
        </svg>
        Home
      </a>
      <span>/</span>
      <a href="/docs" class="hover:text-[color:var(--color-accent)]">Docs</a>
      {
        currentSlug && (
          <>
            <span>/</span>
            <span class="text-[color:var(--color-muted)]">{title}</span>
          </>
        )
      }
    </nav>

    <div class:list={["grid gap-10", gridClass]}>
      <aside class="hidden lg:block">
        <div class="sticky top-20 max-h-[calc(100dvh-6rem)] overflow-y-auto pr-2">
          <DocsSidebar currentSlug={currentSlug} />
        </div>
      </aside>

      <div class="min-w-0">
        <details class="card mb-8 p-3 lg:hidden">
          <summary class="flex cursor-pointer items-center justify-between text-sm font-medium text-[color:var(--color-text)]">
            <span>Documentation menu</span>
            <span class="mono text-xs text-[color:var(--color-dim)]">▾</span>
          </summary>
          <div class="mt-4 border-t border-[color:var(--color-border-soft)] pt-4">
            <DocsSidebar currentSlug={currentSlug} />
          </div>
        </details>

        <article>
          <header class="mb-8 border-b border-[color:var(--color-border-soft)] pb-6">
            <h1 class="heading text-3xl font-bold tracking-tight text-[color:var(--color-text)] sm:text-4xl">
              {title}
            </h1>
            <p class="mt-3 text-[color:var(--color-muted)] leading-relaxed">
              {description}
            </p>
          </header>

          <div class="prose-docs">
            <slot />
          </div>

          {
            editUrl && (
              <div class="mt-12 border-t border-[color:var(--color-border-soft)] pt-6 text-sm">
                <a
                  href={editUrl}
                  target="_blank"
                  rel="noopener"
                  class="text-[color:var(--color-muted)] hover:text-[color:var(--color-accent)]"
                >
                  Edit this page on GitHub
                </a>
              </div>
            )
          }
        </article>
      </div>

      {
        toc.length > 0 && (
          <aside class="hidden xl:block">
            <div class="sticky top-20 max-h-[calc(100dvh-6rem)] overflow-y-auto">
              <p class="mono text-[10px] font-semibold uppercase tracking-wider text-[color:var(--color-dim)]">
                On this page
              </p>
              <ul class="mt-3 space-y-2 border-l border-[color:var(--color-border-soft)] text-sm">
                {toc.map((h) => (
                  <li>
                    <a
                      href={`#${h.slug}`}
                      class:list={[
                        "block border-l border-transparent -ml-px pl-3 text-[color:var(--color-dim)] transition-colors hover:border-[color:var(--color-accent)] hover:text-[color:var(--color-text)]",
                        h.depth === 3 && "pl-6",
                      ]}
                    >
                      {h.text}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        )
      }
    </div>
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
</Layout>
