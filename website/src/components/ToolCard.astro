---
// A recommendation block: title, optional tag and GitHub stars, a description,
// and a button to the tool's site. Pass `repo` ("org/name") for stars and a
// default GitHub link; pass `href` to point the button elsewhere; pass `tag`
// for a small badge (e.g. "same dev as dux").
import GhStars from "./GhStars.astro";

interface Props {
  name: string;
  description: string;
  repo?: string;
  href?: string;
  tag?: string;
}
const { name, description, repo, href, tag } = Astro.props;
const url = href ?? (repo ? `https://github.com/${repo}` : undefined);
const label = url && !url.includes("github.com") ? "Visit site" : "View on GitHub";
---

<div class="tool-card">
  <div class="tool-card-head">
    <div class="tool-card-head-text">
      <div class="tool-card-title-wrap">
        <h3 class="tool-card-title">{name}</h3>
        {tag && <span class="tool-card-tag">{tag}</span>}
      </div>
      {repo && <span class="tool-card-repo">{repo}</span>}
    </div>
    {repo && <GhStars repo={repo} />}
  </div>
  <p class="tool-card-desc">{description}</p>
  {
    url && (
      <a href={url} class="tool-card-btn">
        {label}
      </a>
    )
  }
</div>
